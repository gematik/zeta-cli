<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- The `zeta.stderr.pattern` system property is set in Main.kt to a plain pattern
         when stderr is not a TTY (or NO_COLOR is set), so `zeta 2> file` produces
         plain-text logs. When unset, fall back to the coloured pattern. -->
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>${zeta.stderr.pattern:-%highlight(%-5level) %gray(%logger{24}) - %msg%n}</pattern>
        </encoder>
    </appender>

    <!-- Curlie-style HTTP wire log: emit just the message (already coloured) so
         multi-line bodies aren't prefixed on every line. -->
    <appender name="WIRE" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>
    </appender>

    <logger name="de.gematik.zeta.http.wire" additivity="false">
        <appender-ref ref="WIRE" />
    </logger>

    <!-- Trace tree: emitted once at end of command via log.info when tracing is on.
         Reuses the WIRE appender's `%msg%n` pattern so the multi-line ASCII tree isn't
         prefixed on every line. Level pinned to INFO so the tree prints regardless of
         verbosity. Gating happens at the Tracer (enabled flag), not here. -->
    <logger name="de.gematik.zeta.trace" level="INFO" additivity="false">
        <appender-ref ref="WIRE" />
    </logger>

    <root level="WARN">
        <appender-ref ref="STDERR" />
    </root>
</configuration>
